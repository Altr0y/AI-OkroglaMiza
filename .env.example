# Database Configuration (Supabase PostgreSQL)
# Option 1: Use JDBC connection string (recommended for Supabase)
DB_JDBC_URL=postgresql://user:password@db.your-project.supabase.co:5432/postgres

# Option 2: Use individual parameters (alternative)
# DB_HOST=db.your-project.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-password-here

# Application Configuration
PORT=5000

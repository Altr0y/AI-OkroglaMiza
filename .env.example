# Database Configuration (Supabase PostgreSQL)
# Option 1: Use JDBC connection string (recommended for Supabase)
DB_JDBC_URL=postgresql://user:password@db.your-project.supabase.co:5432/postgres

# Option 2: Use individual parameters (alternative)
# DB_HOST=db.your-project.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your-password-here

# Application Configuration
PORT=5000

# Setup za ollama gpu podporo
# Nvidia kartica: 
OLLAMA_IMAGE=ollama/ollama:latest
GPU_DRIVER=nvidia
GPU_COUNT=all
# AMD kartica:
OLLAMA_IMAGE=ollama/ollama:rocm
GPU_DRIVER=none
GPU_COUNT=0
# ni grafične ;(
OLLAMA_IMAGE=ollama/ollama:latest
GPU_DRIVER=none
GPU_COUNT=0

#V mapi frontend je potrebni narediti file .env.locale, ki zgleda tako:
NEXT_PUBLIC_SUPABASE_URL=skrivnost
NEXT_PUBLIC_SUPABASE_ANON_KEY=skrivnost